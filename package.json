{
  "name": "trythis",
  "version": "1.0.0",
  "description": "Intent Infrastructure: Behavioral system for future actions",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=backend & npm run start --workspace=frontend",
    "backend": "npm run dev --workspace=backend",
    "frontend": "npm start --workspace=frontend",
    "test": "npm test --workspaces",
    "lint": "npm run lint --workspaces",
    "setup": "npm install && npm run setup --workspaces"
  },
  "keywords": [
    "intent",
    "behavioral",
    "recommendations",
    "retention"
  ],
  "author": "TryThis Team",
  "license": "MIT",
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "@types/react": "~18.2.14",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native-web": "~0.19.10",
    "typescript": "^5.1.3"
  }
}
