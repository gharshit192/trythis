# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=mongodb://localhost:27017/trythis
# Explicit database name. Required when DATABASE_URL omits the db (e.g. Atlas
# srv URIs ending in "/?..."), otherwise the app refuses to start rather than
# silently using the default "test" db. Production uses: wanna-try
MONGODB_DB=
MONGODB_USER=
MONGODB_PASSWORD=

# Cache
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=7d

# APIs
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Google AI Studio key (Gemini) — used in the Hindi OCR LLM fallback
GEMINI_API_KEY=
# Google CLOUD Vision (different product from Gemini): enable the Cloud Vision
# API in a GCP project, create a service account, download its JSON key, and
# point this at the file. Primary engine for handwritten Devanagari OCR;
# without it the pipeline falls back to LLMs. Keep the JSON file out of git.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/your-vision-key.json
# Monthly per-image cap to stay inside Vision's free tier (1,000/mo). Once
# reached, OCR falls back to the free LLM path instead of incurring charges.
VISION_MONTHLY_LIMIT=700

# Frontend
FRONTEND_URL=http://localhost:8081

# Queue
QUEUE_CONCURRENCY=5
QUEUE_MAX_ATTEMPTS=3

# Logging
LOG_LEVEL=debug

# Email (Notification Delivery)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-password
EMAIL_FROM=noreply@trythis.app
PUBLIC_BASE_URL=http://localhost:8081

# Web Push (VAPID) — run: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
