# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=mongodb://localhost:27017/trythis
MONGODB_USER=
MONGODB_PASSWORD=

# Cache
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=7d

# APIs
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Frontend
FRONTEND_URL=http://localhost:8081

# Queue
QUEUE_CONCURRENCY=5
QUEUE_MAX_ATTEMPTS=3

# Logging
LOG_LEVEL=debug
